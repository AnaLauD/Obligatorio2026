@model ZanganosSA.Models.Cosecha

@{
    ViewData["Title"] = "Editar Cosecha";
    var selectedColmenas = (List<int>)ViewBag.SelectedColmenas;
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm p-4">
            <h2 class="mb-4"><i class="bi bi-pencil text-warning"></i> Editar Cosecha</h2>
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="mb-3">
                    <label asp-for="Lote" class="form-label fw-bold">Lote</label>
                    <input asp-for="Lote" class="form-control" required />
                    <span asp-validation-for="Lote" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="FechaCosecha" class="form-label fw-bold">Fecha de Cosecha</label>
                    <input asp-for="FechaCosecha" class="form-control" type="date" required />
                    <span asp-validation-for="FechaCosecha" class="text-danger small"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="KgTotal" class="form-label fw-bold">Peso Total (kg)</label>
                    <input asp-for="KgTotal" class="form-control" type="number" step="0.01" required />
                    <span asp-validation-for="KgTotal" class="text-danger small"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="Observaciones" class="form-label fw-bold">Observaciones</label>
                    <textarea asp-for="Observaciones" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="Observaciones" class="text-danger small"></span>
                </div>

                <!-- Colmenas a cosechar -->
                <div class="mb-4">
                    <label class="form-label fw-bold">Colmenas que participaron</label>
                    <div id="colmenas-container" class="border rounded p-3 bg-white" style="max-height: 250px; overflow-y: auto;">
                        @if (ViewBag.Colmenas != null)
                        {
                            var colmenasGrouped = ((List<ZanganosSA.Models.Colmena>)ViewBag.Colmenas).GroupBy(c => c.Apiario!.Departamento);
                            foreach (var group in colmenasGrouped)
                            {
                                <div class="fw-bold text-success border-bottom pb-1 mb-2">Apiario: @group.Key</div>
                                foreach (var colmena in group)
                                {
                                    bool isChecked = selectedColmenas != null && selectedColmenas.Contains(colmena.Id);
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="selectedColmenas" value="@colmena.Id" id="colmena_@colmena.Id" @(isChecked ? "checked" : "")>
                                        <label class="form-check-label" for="colmena_@colmena.Id">
                                            <strong>Colmena #@colmena.Id</strong> 
                                            <span class="text-muted small">(Tipo: @colmena.TipoCaja | Estado: @colmena.EstadoColmena | Reina: @colmena.ReinaEstado)</span>
                                        </label>
                                    </div>
                                }
                            }
                        }
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold"><i class="bi bi-save"></i> Guardar Cambios</button>
                    <a asp-action="Index" class="btn-paginado-dorado"><i class="bi bi-arrow-left"></i> Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
