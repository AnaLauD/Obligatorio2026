@model IEnumerable<ZanganosSA.Models.Cosecha>

@{
    ViewData["Title"] = "Cosechas";
}

<div class="card shadow-sm p-4 mb-4 border-success" style="border-top: 4px solid #198754;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0 text-success"><i class="bi bi-basket-fill"></i> Cosechas</h2>
        <a asp-action="Create" class="btn btn-success fw-bold"><i class="bi bi-plus-circle"></i> Nueva Cosecha</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Id Cosecha</th>
                    <th>Lote</th>
                    <th>Fecha de Cosecha</th>
                    <th>Peso Total (kg)</th>
                    <th>Observaciones</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.Id</td>
                        <td><strong>@item.Lote</strong></td>
                        <td>@item.FechaCosecha.ToString("dd/MM/yyyy")</td>
                        <td><strong>@item.KgTotal kg</strong></td>
                        <td class="text-muted small">@item.Observaciones</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil"></i> Editar</a>
                            <a asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye"></i> Detalles</a>
                            <a asp-action="Delete" asp-route-id="@item.Id"><i class="bi bi-trash"></i> Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4">
        <div>
            <span class="text-muted small">Página @ViewBag.CurrentPage de @(ViewBag.TotalPages == 0 ? 1 : ViewBag.TotalPages)</span>
        </div>
        <div class="d-flex gap-2">
            @if (ViewBag.HasPreviousPage)
            {
                <a href="?page=@(ViewBag.CurrentPage - 1)" class="btn btn-outline-success"><i class="bi bi-arrow-left"></i> Anterior</a>
            }
            else
            {
                <span class="btn btn-outline-success disabled"><i class="bi bi-arrow-left"></i> Anterior</span>
            }

            @if (ViewBag.HasNextPage)
            {
                <a href="?page=@(ViewBag.CurrentPage + 1)" class="btn btn-outline-success">Siguiente <i class="bi bi-arrow-right"></i></a>
            }
            else
            {
                <span class="btn btn-outline-success disabled">Siguiente <i class="bi bi-arrow-right"></i></span>
            }
        </div>
    </div>
</div>

