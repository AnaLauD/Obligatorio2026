@model ZanganosSA.Models.Apiario

@{
    ViewData["Title"] = "Editar Apiario";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm p-4">
            <h2 class="mb-4"><i class="bi bi-pencil text-warning"></i> Editar Apiario</h2>
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label asp-for="Departamento" class="form-label fw-bold">Departamento</label>
                    <input asp-for="Departamento" class="form-control" required />
                    <span asp-validation-for="Departamento" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="SeccionalPolicial" class="form-label fw-bold">Seccional Policial</label>
                    <input asp-for="SeccionalPolicial" class="form-control" />
                    <span asp-validation-for="SeccionalPolicial" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="FechaRegistro" class="form-label fw-bold">Fecha de Registro</label>
                    <input asp-for="FechaRegistro" class="form-control" type="date" required />
                    <span asp-validation-for="FechaRegistro" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Latitud" class="form-label fw-bold">Latitud</label>
                    <input asp-for="Latitud" class="form-control" type="number" step="0.00000001" />
                    <span asp-validation-for="Latitud" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Longitud" class="form-label fw-bold">Longitud</label>
                    <input asp-for="Longitud" class="form-control" type="number" step="0.00000001" />
                    <span asp-validation-for="Longitud" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold"><i class="bi bi-save"></i> Guardar Cambios</button>
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
