                        <!-- AI Vision Error Card -->
                        <div class="card border-0 rounded-3 text-white p-3 d-none mb-3" id="visionErrorCard" style="background: rgba(239, 68, 68, 0.15); border: 1px solid rgba(239, 68, 68, 0.4) !important;">
                            <div class="d-flex align-items-center">
                                <div class="me-3">
                                    <i class="bi bi-exclamation-triangle-fill text-danger fs-3"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1 text-danger fw-bold">Error de Análisis Visual</h6>
