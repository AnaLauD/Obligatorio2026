                        </div>

                    </div>
                </div>
            </div>

            <!-- RIGHT PANEL: Computer Vision Image / Camera Area -->
            <div class="col-lg-6 mb-4">
                <div class="card bg-dark text-white border-0 shadow-lg rounded-4 overflow-hidden h-100" style="background: rgba(30, 41, 59, 0.7) !important; backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.1) !important;">
                    <div class="card-header bg-transparent border-bottom border-secondary py-3 d-flex justify-content-between align-items-center">
                        <h4 class="mb-0 text-warning"><i class="bi bi-camera-fill me-2"></i>Visión Computacional en Tiempo Real</h4>
                        <span class="badge bg-warning text-dark rounded-pill px-3 py-2" id="visionStatusBadge">Cámara Lista</span>
                    </div>
                    <div class="card-body p-4 d-flex flex-column justify-content-between">
                        <!-- Camera Viewport / Image Area -->
                        <div class="position-relative bg-black rounded-4 overflow-hidden mb-4 d-flex align-items-center justify-content-center" style="height: 300px; border: 1px solid rgba(255, 255, 255, 0.15);">
                            <!-- Scanner Laser Effect -->
                            <div class="scanner-laser d-none" id="scannerLaser"></div>
                            
                            <!-- Main Preview Image -->
                            <img id="visionImagePreview" src="/images/beehive_inspection.png" class="w-100 h-100 object-fit-cover" alt="Vista de Inspección" />
                            
                            <!-- Live Camera Video (if supported/activated) -->
                            <video id="webcamVideo" class="w-100 h-100 object-fit-cover d-none" autoplay playsinline></video>

                            <!-- Bounding Boxes Container -->
                            <div class="position-absolute top-0 start-0 w-100 h-100" id="boundingBoxesContainer" style="pointer-events: none;"></div>
                        </div>
                        <!-- Camera Simulation Control Panel -->
                        <div id="cameraSimulationControls" class="mb-4 d-none p-3 rounded-4 bg-secondary bg-opacity-10 border border-warning text-center">
                            <label class="form-label text-warning fw-bold small uppercase d-block mb-2"><i class="bi bi-gear-fill me-1"></i>Simulador de Objeto Frente a Cámara:</label>
                            <div class="d-flex flex-wrap gap-2 justify-content-center">
                                <button type="button" class="btn btn-sm btn-outline-warning active rounded-pill px-3 camera-sim-preset" data-preset="beehive_inspection">
                                    <i class="bi bi-box-seam me-1"></i> Cajón Dañado (Madera)
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-warning rounded-pill px-3 camera-sim-preset" data-preset="healthy_honeycomb">
                                    <i class="bi bi-grid-3x3-gap-fill me-1"></i> Panal Saludable
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3 camera-sim-preset" data-preset="non_apiculture">
                                    <i class="bi bi-x-circle-fill me-1"></i> Mano / Objeto Inválido
                                </button>
                            </div>
                        </div>

                        <!-- Interactive Controls -->
                        <div class="d-flex flex-wrap gap-2 justify-content-center mb-4">
                            <button type="button" class="btn btn-outline-warning btn-md rounded-pill px-3" id="toggleWebcamBtn">
                                <i class="bi bi-camera me-1"></i> Usar Cámara Real
                            </button>
                            <button type="button" class="btn btn-warning btn-md rounded-pill text-dark fw-bold px-4" id="analyzeBtn">
                                <i class="bi bi-cpu-fill me-1"></i> Iniciar Escaneo IA
                            </button>
                        </div>

                        <!-- Upload Custom Image Area -->
                        <div class="mb-4 p-3 rounded-3 bg-secondary bg-opacity-10 border border-secondary border-dashed text-center">
                            <label class="form-label text-muted fw-bold small uppercase d-block mb-2">Subir Foto para Analizar:</label>
                            <input type="file" id="customImageUpload" class="form-control bg-dark text-light border-secondary rounded-pill" accept="image/*" />
                            <div class="text-muted small mt-1">Sube una foto de colmena/panal (o cualquier otra para probar el error de análisis)</div>
                        </div>

                        <!-- Image Presets Selector -->
                        <div class="mb-4">
                            <label class="form-label text-muted fw-bold small uppercase">Imágenes de Prueba (Simulador):</label>
                            <div class="row g-2">
                                <div class="col-4">
                                    <div class="card bg-secondary bg-opacity-25 border border-warning rounded-3 p-2 cursor-pointer preset-img-card active" data-preset="beehive_inspection" data-src="/images/beehive_inspection.png" style="cursor: pointer; height: 110px;">
                                        <img src="/images/beehive_inspection.png" class="w-100 rounded object-fit-cover" style="height: 50px;" />
                                        <div class="text-center mt-1 small" style="font-size: 11px;">Cajón Viejo (Madera)</div>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="card bg-secondary bg-opacity-25 border border-secondary rounded-3 p-2 cursor-pointer preset-img-card" data-preset="healthy_honeycomb" data-src="/images/healthy_honeycomb.png" style="cursor: pointer; height: 110px;">
                                        <img src="/images/healthy_honeycomb.png" class="w-100 rounded object-fit-cover" style="height: 50px;" />
                                        <div class="text-center mt-1 small" style="font-size: 11px;">Panal Saludable</div>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="card bg-secondary bg-opacity-25 border border-secondary rounded-3 p-2 cursor-pointer preset-img-card" data-preset="non_apiculture" data-src="/images/unrelated_car.png" style="cursor: pointer; height: 110px;">
                                        <img src="/images/unrelated_car.png" class="w-100 rounded object-fit-cover" style="height: 50px;" />
                                        <div class="text-center mt-1 small text-danger" style="font-size: 11px; font-weight: bold;"><i class="bi bi-x-octagon"></i> Foto Invalida</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- AI Vision Results Card -->
                        <div class="card bg-secondary bg-opacity-20 border border-secondary rounded-3 p-3 d-none mb-3" id="visionResultCard">
                            <h6 class="text-warning fw-bold border-bottom border-secondary pb-2 mb-2"><i class="bi bi-cpu-fill me-1"></i>Resultados del Análisis Visual IA</h6>
                            <div class="row">
                                <div class="col-sm-6">
                                    <span class="text-muted small">Estructura Detectada:</span>
                                    <p class="fw-semibold mb-2" id="visionMaterialType">-</p>
                                </div>
                                <div class="col-sm-6">
                                    <span class="text-muted small">Precisión:</span>
                                    <p class="fw-semibold mb-2 text-success" id="visionConfidence">-</p>
                                </div>
                                <div class="col-12">
                                    <span class="text-muted small">Diagnóstico / Condición de Mantenimiento:</span>
                                    <p class="fw-semibold mb-0 text-info" id="visionCondition">-</p>
                                </div>
