@model IEnumerable<ZanganosSA.Models.Alimentacion>
@{
    ViewData["Title"] = "Alimentación Suplementaria";
}

<div class="card shadow-sm p-4 mb-4 border-info">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0 text-info"><i class="bi bi-calendar-event"></i> Alimentación Suplementaria</h2>
        <a asp-action="Create" class="btn btn-info text-white fw-bold"><i class="bi bi-plus-circle"></i> Programar Alimentación</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Fecha Programada</th>
                    <th>Apiario (Depto)</th>
                    <th>Tipo de Alimento</th>
                    <th>Cantidad (kg)</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FechaProgramada.ToString("dd/MM/yyyy")</td>
                        <td><strong>@item.Apiario?.Departamento</strong></td>
                        <td>@item.TipoAlimento</td>
                        <td>@(item.Cantidad.HasValue ? $"{item.Cantidad.Value.ToString("N2")} kg" : "N/A")</td>
                        <td>
                            @if (item.FechaProgramada < DateTime.Today)
                            {
                                <span class="badge bg-success">Entregado</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pendiente</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil"></i> Editar</a>
                            <a asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye"></i> Detalles</a>
                            <a asp-action="Delete" asp-route-id="@item.Id"><i class="bi bi-trash"></i> Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4">
        <div>
            <span class="text-muted small">Página @ViewBag.CurrentPage de @(ViewBag.TotalPages == 0 ? 1 : ViewBag.TotalPages)</span>
        </div>
        <div class="d-flex gap-2">
            @if (ViewBag.HasPreviousPage)
            {
                <a href="?page=@(ViewBag.CurrentPage - 1)" class="btn btn-outline-info"><i class="bi bi-arrow-left"></i> Anterior</a>
            }
            else
            {
                <span class="btn btn-outline-info disabled"><i class="bi bi-arrow-left"></i> Anterior</span>
            }

            @if (ViewBag.HasNextPage)
            {
                <a href="?page=@(ViewBag.CurrentPage + 1)" class="btn btn-outline-info">Siguiente <i class="bi bi-arrow-right"></i></a>
            }
            else
            {
                <span class="btn btn-outline-info disabled">Siguiente <i class="bi bi-arrow-right"></i></span>
            }
        </div>
    </div>
</div>
