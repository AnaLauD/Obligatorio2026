@model ZanganosSA.Models.Alimentacion
@{
    ViewData["Title"] = "Eliminar Alimentación";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm p-4 border-danger">
            <h2 class="mb-2 text-danger"><i class="bi bi-exclamation-triangle"></i> Eliminar Alimentación</h2>
            <p class="text-muted mb-4">¿Estás seguro de que deseas eliminar esta programación de alimentación? Esta acción no se puede deshacer.</p>
            <dl class="row">
                <dt class="col-sm-4 fw-bold">Alimentación N°</dt>
                <dd class="col-sm-8">#@Model.Id</dd>
                <dt class="col-sm-4 fw-bold">Apiario (Depto)</dt>
                <dd class="col-sm-8">@Model.Apiario?.Departamento</dd>
                <dt class="col-sm-4 fw-bold">Tipo de Alimento</dt>
                <dd class="col-sm-8">@Model.TipoAlimento</dd>
                <dt class="col-sm-4 fw-bold">Fecha Programada</dt>
                <dd class="col-sm-8">@Model.FechaProgramada.ToString("dd/MM/yyyy")</dd>
            </dl>
            <form asp-action="Delete" class="d-flex gap-2 mt-3">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger fw-bold"><i class="bi bi-trash"></i> Sí, eliminar</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Cancelar</a>
            </form>
        </div>
    </div>
</div>
