@model ZanganosSA.Models.Barril

@{
    ViewData["Title"] = "Editar Barril";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm p-4">
            <h2 class="mb-4"><i class="bi bi-pencil text-warning"></i> Editar Barril de Exportación</h2>
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label asp-for="CosechaId" class="form-label fw-bold">Cosecha de Origen (Lote)</label>
                    <select asp-for="CosechaId" class="form-select" asp-items="ViewBag.CosechaId" required></select>
                    <span asp-validation-for="CosechaId" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="PesoKg" class="form-label fw-bold">Peso Neto (kg)</label>
                    <input asp-for="PesoKg" class="form-control" type="number" step="0.01" required />
                    <span asp-validation-for="PesoKg" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Estado" class="form-label fw-bold">Estado</label>
                    <select asp-for="Estado" class="form-select">
                        <option value="Listo">Listo</option>
                        <option value="Exportado">Exportado</option>
                        <option value="Reservado">Reservado</option>
                    </select>
                    <span asp-validation-for="Estado" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Destino" class="form-label fw-bold">Destino</label>
                    <input asp-for="Destino" class="form-control" />
                    <span asp-validation-for="Destino" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold"><i class="bi bi-save"></i> Guardar Cambios</button>
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
