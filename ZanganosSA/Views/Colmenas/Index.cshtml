@model IEnumerable<ZanganosSA.Models.Colmena>

@{
    ViewData["Title"] = "Colmenas";
}

<div class="card shadow-sm p-4 mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0 text-warning"><i class="bi bi-box-seam"></i> Colmenas</h2>
        <a asp-action="Create" class="btn btn-warning fw-bold"><i class="bi bi-plus-circle"></i> Nueva Colmena</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle table-honey">
            <thead>
                <tr>
                    <th>Id Colmena</th>
                    <th>Apiario (Depto)</th>
                    <th>Tipo Caja</th>
                    <th>Estado Colmena</th>
                    <th>Estado Reina</th>
                    <th>Activa</th>
                    <th>Observaciones</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>#@item.Id</strong></td>
                        <td><i class="bi bi-geo-alt text-muted"></i> @item.Apiario!.Departamento</td>
                        <td>@item.TipoCaja</td>
                        <td>
                            @{
                                string badgeClass = item.EstadoColmena == "Fuerte" ? "bg-success" : (item.EstadoColmena == "Critica" || item.EstadoColmena == "Debil" ? "bg-danger" : "bg-warning text-dark");
                            }
                            <span class="badge @badgeClass">@item.EstadoColmena</span>
                        </td>
                        <td>@item.ReinaEstado</td>
                        <td><span class="badge @(item.Activa ? "bg-success" : "bg-secondary")">@(item.Activa ? "Sí" : "No")</span></td>
                        <td class="text-muted small">@item.Observaciones</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil"></i> Editar</a>
                            <a asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye"></i> Detalles</a>
                            <a asp-action="Delete" asp-route-id="@item.Id"><i class="bi bi-trash"></i> Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4">
        <div>
            <span class="text-muted small">Página @ViewBag.CurrentPage de @(ViewBag.TotalPages == 0 ? 1 : ViewBag.TotalPages)</span>
        </div>
        <div class="d-flex gap-2">
            @if (ViewBag.HasPreviousPage)
            {
                <a href="?page=@(ViewBag.CurrentPage - 1)" class="btn-paginado-dorado"><i class="bi bi-arrow-left"></i> Anterior</a>
            }
            else
            {
                <span class="btn-paginado-dorado disabled"><i class="bi bi-arrow-left"></i> Anterior</span>
            }

            @if (ViewBag.HasNextPage)
            {
                <a href="?page=@(ViewBag.CurrentPage + 1)" class="btn-paginado-dorado">Siguiente <i class="bi bi-arrow-right"></i></a>
            }
            else
            {
                <span class="btn-paginado-dorado disabled">Siguiente <i class="bi bi-arrow-right"></i></span>
            }
        </div>
    </div>
</div>

